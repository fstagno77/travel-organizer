{
  "name": "travel-organizer",
  "version": "1.0.0",
  "description": "Personal travel organizer with PDF document processing",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest",
    "docs:dev": "cd docs && npx vitepress dev",
    "docs:build": "cd docs && npx vitepress build",
    "screenshots:login": "node scripts/take-screenshots.js --login",
    "screenshots:session": "node scripts/save-session.js",
    "screenshots": "node scripts/take-screenshots.js",
    "screenshots:help": "node scripts/take-screenshots.js --help"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@supabase/supabase-js": "^2.90.1",
    "busboy": "^1.6.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "jest": "^30.2.0",
    "pdf-parse": "^1.1.1",
    "vite": "^6.4.1"
  }
}
